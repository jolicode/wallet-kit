# Template — copy to .env.local and fill in your real values.
# .env is committed; .env.local is gitignored and overrides these values.

# 10-character Team Identifier from developer.apple.com → Membership
APPLE_TEAM_IDENTIFIER=

# Pass Type Identifier you registered, e.g. pass.com.example.coupon
APPLE_PASS_TYPE_IDENTIFIER=

# Absolute path to the Pass Type ID .p12 certificate (exported from Keychain)
APPLE_CERTIFICATE_PATH=/absolute/path/to/pass-type-id.p12

# Password you set when exporting the .p12 (leave empty if none)
APPLE_CERTIFICATE_PASSWORD=

# Absolute path to a 29x29 (or 58x58 / 87x87) PNG used as the pass icon
APPLE_ICON_PATH=/absolute/path/to/icon.png

# --- Optional: APNS push (only used by test-push.php) ---

# Absolute path to the .p8 APNS auth key
APPLE_APNS_KEY_PATH=

# 10-character Key ID shown next to the .p8 key in developer.apple.com
APPLE_APNS_KEY_ID=

# Push token + serial number of a pass registered via your Web Service
# (populated after an actual device registers — test-push.php prints guidance)
APPLE_PUSH_TOKEN=
APPLE_PASS_SERIAL_NUMBER=
