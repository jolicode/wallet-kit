# Template — copy to .env.local and fill in your real values.
# .env is committed; .env.local is gitignored and overrides these values.

# 16-digit numeric Google Wallet Issuer ID (from wallet.google.com/business/console, eg. 3388000000012345)
GOOGLE_WALLET_ISSUER_ID=

# Absolute path to your Google service account JSON file
GOOGLE_WALLET_SERVICE_ACCOUNT_PATH=/absolute/path/to/google-sa.json

# Used only by test-update.php — the classId/objectId created by test-api.php
GOOGLE_WALLET_CLASS_ID=
GOOGLE_WALLET_OBJECT_ID=
