# Template — copy to .env.local and fill in your real values.
# .env is committed; .env.local is gitignored and overrides these values.

# Partner ID from the Samsung Wallet Business Portal
SAMSUNG_PARTNER_ID=

# Absolute path to the RSA PEM private key whose public half you uploaded to the portal
SAMSUNG_PRIVATE_KEY_PATH=/absolute/path/to/samsung-private.pem

# Optional Service ID (only needed if the portal assigned one to your partner account)
SAMSUNG_SERVICE_ID=

# Region: US, EU, or KR — must match the portal you registered on
SAMSUNG_REGION=EU

# Used only by test-push.php — the cardId printed by test-api.php
SAMSUNG_CARD_ID=
